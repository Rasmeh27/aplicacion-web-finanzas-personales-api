NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_SSL=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Server-only secret. Never expose it through NEXT_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Service (internal, server-to-server). The frontend never calls it directly.
AI_SERVICE_BASE_URL=http://localhost:8001
# Must match AI_SERVICE_INTERNAL_API_KEY in the ai-service; use a strong key.
AI_SERVICE_INTERNAL_API_KEY=change-me
AI_SERVICE_TIMEOUT_MS=30000

# Internal key that PROTECTS this backend's internal endpoints
# (POST /api/v1/internal/assistant/financial-context, called by the ai-service).
# Must match BACKEND_INTERNAL_API_KEY in the ai-service .env; use a strong key.
# The endpoint returns 500 while this is empty or still "change-me".
BACKEND_INTERNAL_API_KEY=change-me
