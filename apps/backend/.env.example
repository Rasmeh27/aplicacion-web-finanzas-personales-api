NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_SSL=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Required only for backend-generated auth links such as password recovery.
# Never expose this key to the frontend.
SUPABASE_SERVICE_ROLE_KEY=

# --- Transactional email -----------------------------------------------------
# 'emailjs' sends recovery emails through EmailJS REST API.
# 'console' logs recovery links in backend logs for local-only testing.
# unset/disabled falls back to Supabase Auth email delivery.
EMAIL_PROVIDER=emailjs
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_PASSWORD_RESET_ID=
EMAILJS_TEMPLATE_PREMIUM_ALERT_ID=
EMAILJS_TEMPLATE_SIGNUP_CONFIRMATION_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAIL_SUPPORT_ADDRESS=soporte@moni.local
NEWS_API_KEY=

# AI Service (internal, server-to-server). The frontend never calls it directly.
AI_SERVICE_BASE_URL=http://127.0.0.1:8001
# Must match AI_SERVICE_INTERNAL_API_KEY in the ai-service; use a strong key.
AI_SERVICE_INTERNAL_API_KEY=change-me
AI_SERVICE_TIMEOUT_MS=60000

# Internal key that PROTECTS this backend's internal endpoints
# (POST /api/v1/internal/assistant/financial-context, called by the ai-service).
# Must match BACKEND_INTERNAL_API_KEY in the ai-service .env; use a strong key.
# The endpoint returns 500 while this is empty or still "change-me".
BACKEND_INTERNAL_API_KEY=change-me

# --- Market data (Premium investments) --------------------------------------
# Provider selection is EXPLICIT (no silent fallback to mock):
#   'twelve_data' -> real data via the official Twelve Data API (needs a key).
#   'alphavantage'-> real data via Alpha Vantage (needs a key).
#   'mock'        -> deterministic demo data, no network; every payload is
#                    flagged isMock=true so the frontend shows "Datos demo".
# If a real provider is selected without its key, the backend FAILS at startup
# (it never degrades to mock). In production an unset value is also an error.
MARKET_DATA_PROVIDER=alphavantage

# Alpha Vantage (https://www.alphavantage.co). Get a free API key there.
# ALPHA_VANTAGE_API_KEY is the CANONICAL variable for this provider.
# NEVER expose this key to the frontend or print it in logs.
ALPHA_VANTAGE_API_KEY=
# Legacy alias, kept only for backward compatibility (prefer ALPHA_VANTAGE_API_KEY).
MARKET_DATA_API_KEY=

# Twelve Data (alternative real provider): set MARKET_DATA_PROVIDER=twelve_data.
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# Optional base URL override for the active provider.
MARKET_DATA_BASE_URL=
MARKET_DATA_TIMEOUT_MS=8000
# Max concurrent quote requests to the provider when enriching a portfolio.
MARKET_DATA_MAX_CONCURRENCY=4
# Backend cache TTLs (quotes ~60s, symbol search ~5min, history ~15min).
MARKET_DATA_QUOTE_CACHE_TTL_MS=60000
MARKET_DATA_SEARCH_CACHE_TTL_MS=300000
MARKET_DATA_HISTORY_CACHE_TTL_MS=900000
# Max age of a cached value that can be served as 'stale' when the provider is down.
MARKET_DATA_STALE_MAX_AGE_MS=86400000
