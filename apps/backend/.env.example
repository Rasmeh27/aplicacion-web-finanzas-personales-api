# ==========================================================================
# MONI backend — variables de entorno (ejemplo, SIN valores reales)
# Obligatoria = el backend no arranca sin ella.
# ==========================================================================

# --- Runtime ----------------------------------------------------------------
# Obligatoria. 'development' | 'production'
NODE_ENV=development
# En Render NO definas PORT: la plataforma lo inyecta y el backend lo usa.
# API_PORT es solo el fallback para desarrollo local.
API_PORT=3001
# Orígenes permitidos por CORS. Uno o varios separados por coma (se ignoran
# espacios y vacíos). NO usar '*'. Obligatoria en producción.
#   Local:      http://localhost:3000
#   Producción: https://moni-web.onrender.com,https://app.midominio.com
FRONTEND_URL=http://localhost:3000

# --- Base de datos (Supabase / PostgreSQL) ----------------------------------
# Obligatoria. Cadena de conexión Postgres (SECRETA, contiene la contraseña).
DATABASE_URL=postgresql://user:password@host:5432/postgres
# 'true' para conexiones TLS a Supabase (recomendado en producción).
DATABASE_SSL=true

# --- Supabase Auth -----------------------------------------------------------
# Obligatorias. La autenticación (login/registro/refresh) se delega a Supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Swagger -----------------------------------------------------------------
# Opcional. Si se define, controla explícitamente la documentación:
#   'true'  -> expone /api/docs y /api/docs-json
#   'false' -> desactivada (recomendado en producción)
# Si se omite, queda activa solo cuando NODE_ENV != production.
ENABLE_SWAGGER=false

# --- AI Service (interno, servidor-a-servidor) ------------------------------
# El frontend NUNCA llama al AI Service directamente ni conoce estas claves.
# Requeridas para que el AI Assistant funcione; si faltan, el assistant
# responde 503 pero el resto del backend arranca igual.
AI_SERVICE_BASE_URL=http://127.0.0.1:8001
# SECRETA. Debe coincidir con AI_SERVICE_INTERNAL_API_KEY en el ai-service.
AI_SERVICE_INTERNAL_API_KEY=change-me
AI_SERVICE_TIMEOUT_MS=60000

# Clave interna que PROTEGE los endpoints internos de ESTE backend
# (POST /api/v1/internal/assistant/financial-context, llamado por el ai-service).
# SECRETA. Debe coincidir con BACKEND_INTERNAL_API_KEY en el ai-service.
BACKEND_INTERNAL_API_KEY=change-me

# --- Market data (inversiones premium) --------------------------------------
# Selección EXPLÍCITA (sin fallback silencioso a mock):
#   'twelve_data' -> datos reales (requiere TWELVE_DATA_API_KEY)
#   'alphavantage'-> datos reales (requiere ALPHA_VANTAGE_API_KEY)
#   'mock'        -> demo determinista, sin red (isMock=true)
# Si se elige un proveedor real sin su key, el backend FALLA al arrancar.
# En producción un valor vacío también es error.
MARKET_DATA_PROVIDER=alphavantage

# Alpha Vantage (https://www.alphavantage.co). SECRETA. Nunca exponer al frontend
# ni imprimir en logs. ALPHA_VANTAGE_API_KEY es la variable CANÓNICA.
ALPHA_VANTAGE_API_KEY=
# Alias heredado (prefiere ALPHA_VANTAGE_API_KEY).
MARKET_DATA_API_KEY=

# Twelve Data (proveedor real alternativo): usar MARKET_DATA_PROVIDER=twelve_data.
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# Override opcional de la base URL del proveedor activo.
MARKET_DATA_BASE_URL=
MARKET_DATA_TIMEOUT_MS=8000
# Máximo de cotizaciones concurrentes al enriquecer un portafolio.
MARKET_DATA_MAX_CONCURRENCY=4
# TTLs de caché del backend (quotes ~60s, búsqueda ~5min, histórico ~15min).
MARKET_DATA_QUOTE_CACHE_TTL_MS=60000
MARKET_DATA_SEARCH_CACHE_TTL_MS=300000
MARKET_DATA_HISTORY_CACHE_TTL_MS=900000
# Edad máxima de un valor en caché servible como 'stale' si el proveedor cae.
MARKET_DATA_STALE_MAX_AGE_MS=86400000

# --- Tasas de cambio a moneda base (DOP) ------------------------------------
# Opcionales. Tasas oficiales del BCRD en RD$ por 1 USD (defaults si se omiten).
EXCHANGE_RATE_USD_BUY=58.36
EXCHANGE_RATE_USD_SELL=58.95

# --- Solo desarrollo local ---------------------------------------------------
# 'true' arranca el backend mock (LocalDevModule) sin BD real. NUNCA en producción.
LOCAL_MOCK_BACKEND=false
