# Local development
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Tasas de cambio a moneda base (DOP). Tasas oficiales del BCRD en RD$ por 1 USD.
# Se aplican al crear/actualizar movimientos: compra (buy) a ingresos, venta
# (sell) a gastos. Si se omiten, se usan los defaults indicados.
EXCHANGE_RATE_USD_BUY=58.36
EXCHANGE_RATE_USD_SELL=58.95

# Supabase / PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_SSL=true

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Temporary local cache used by docker-compose.dev.yml
REDIS_URL=redis://localhost:6379

# Optional integrations
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Market data (Premium investments). Selección EXPLÍCITA, sin fallback a mock:
#   'alphavantage' = API oficial (requiere ALPHA_VANTAGE_API_KEY, variable canónica)
#   'twelve_data' = API oficial (requiere TWELVE_DATA_API_KEY)
#   'mock' = demo determinista sin red (isMock=true en cada respuesta)
MARKET_DATA_PROVIDER=alphavantage
ALPHA_VANTAGE_API_KEY=
# Alias heredado (usa ALPHA_VANTAGE_API_KEY):
MARKET_DATA_API_KEY=
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
MARKET_DATA_BASE_URL=
MARKET_DATA_TIMEOUT_MS=8000
MARKET_DATA_MAX_CONCURRENCY=4
MARKET_DATA_QUOTE_CACHE_TTL_MS=60000
MARKET_DATA_SEARCH_CACHE_TTL_MS=300000
MARKET_DATA_HISTORY_CACHE_TTL_MS=900000
MARKET_DATA_STALE_MAX_AGE_MS=86400000
NEWS_API_KEY=
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=noreply@smartwallet.app
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=smartwallet-files
AWS_REGION=us-east-1
