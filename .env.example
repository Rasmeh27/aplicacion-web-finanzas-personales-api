# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/smartwallet
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=smartwallet
DATABASE_USER=user
DATABASE_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Provider ───────────────────────────────────────────
AI_PROVIDER=anthropic           # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Market Data ───────────────────────────────────────────
MARKET_DATA_PROVIDER=alphavantage
ALPHA_VANTAGE_API_KEY=

# ── News ──────────────────────────────────────────────────
NEWS_API_KEY=

# ── Email ─────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid         # sendgrid | ses | mailgun
SENDGRID_API_KEY=
EMAIL_FROM=noreply@smartwallet.app

# ── Storage ───────────────────────────────────────────────
STORAGE_PROVIDER=s3             # s3 | spaces | minio
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=smartwallet-files
AWS_REGION=us-east-1

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000
